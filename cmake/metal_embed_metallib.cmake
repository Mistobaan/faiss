if(NOT DEFINED INPUT OR NOT DEFINED OUTPUT OR NOT DEFINED MODE)
  message(FATAL_ERROR "INPUT, OUTPUT, and MODE must be defined")
endif()

file(READ "${INPUT}" METAL_HEX HEX)
string(REGEX MATCHALL ".." METAL_BYTES "${METAL_HEX}")

set(CONTENT "")
set(COUNT 0)
foreach(BYTE ${METAL_BYTES})
  if(COUNT EQUAL 0)
    string(APPEND CONTENT "    ")
  endif()
  string(APPEND CONTENT "0x${BYTE}, ")
  math(EXPR COUNT "${COUNT} + 1")
  if(COUNT EQUAL 12)
    string(APPEND CONTENT "\n")
    set(COUNT 0)
  endif()
endforeach()

if(NOT COUNT EQUAL 0)
  string(APPEND CONTENT "\n")
endif()

file(WRITE "${OUTPUT}" "/* Generated by metal_embed_metallib.cmake. */\n")
file(APPEND "${OUTPUT}" "#include <cstddef>\n#include <cstdint>\n\n")
file(APPEND "${OUTPUT}" "namespace faiss::metal::impl {\n")
file(APPEND "${OUTPUT}" "extern const uint8_t kMetalLibraryData[] = {\n${CONTENT}};\n")
file(APPEND "${OUTPUT}" "extern const size_t kMetalLibrarySize = sizeof(kMetalLibraryData);\n")
if(MODE STREQUAL "SOURCE")
  file(APPEND "${OUTPUT}" "extern const bool kMetalLibraryIsSource = true;\n")
else()
  file(APPEND "${OUTPUT}" "extern const bool kMetalLibraryIsSource = false;\n")
endif()
file(APPEND "${OUTPUT}" "} // namespace faiss::metal::impl\n")
